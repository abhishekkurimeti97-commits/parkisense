# Example Configuration File
# Do NOT place real secrets in this file. Copy this file to `.env` and fill in your details.

# 1. MongoDB Connection String (REQUIRED)
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/parkisense
MONGODB_URI=your_mongodb_connection_string

# 2. Flask Secret Key (REQUIRED for session security)
# Generate a random string for this (e.g. using `python -c "import secrets; print(secrets.token_hex(24))"`)
SECRET_KEY=your_secret_key

# 3. Encryption Key (REQUIRED for encrypting user data in the database)
# Generate using `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=your_encryption_key

# Optional: Set to 'production' or 'development'
FLASK_ENV=development
